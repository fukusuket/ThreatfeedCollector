LLM_PROVIDER=openai
OPENAI_API_KEY=your-open-api-key
AWS_REGION=ap-northeast-1
# Newer Claude models require a cross-region inference profile ID
# (region-prefixed: apac. / us. / eu.), not the on-demand model ID.
BEDROCK_MODEL_ID=apac.anthropic.claude-opus-4-8
MISP_URL=https://misp-core
MISP_KEY=your-misp-key
DAYS_BACK=7